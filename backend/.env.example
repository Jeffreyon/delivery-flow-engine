# Server
PORT=5000
FRONTEND_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# PostgreSQL
DATABASE_URL=postgres://postgres@127.0.0.1:6446/delivery_flow_engine

# Auth
JWT_SECRET=replace-with-a-secret
JWT_EXPIRATION_SECONDS=3600

# Session cookies
SESSION_COOKIE_NAME=local_session
SESSION_COOKIE_MAX_AGE_DAYS=7
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=Scaffold Admin

# Storage
STORAGE_DIRECTORY=storage
STORAGE_URL_PREFIX=http://127.0.0.1:5000/storage
